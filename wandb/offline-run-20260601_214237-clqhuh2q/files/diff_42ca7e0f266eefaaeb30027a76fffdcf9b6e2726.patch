-        intervened = np.linalg.norm(u_safe - u_nom) > 1e-4
-        return u_safe, intervened
-
-    # fallback: bang-bang on the BRT gradient
-    u_fallback = np.array([
-        u_max * np.sign(a_cbf[0]),
-        u_max * np.sign(a_cbf[1]),
-        u_max * np.sign(a_cbf[2]),
-    ], dtype=np.float32)
-    return u_fallback, True
