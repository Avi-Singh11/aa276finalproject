-def _dist_point_to_segment(p, a, b):
-    ab = b - a
-    ab_sq = np.dot(ab, ab)
-    if ab_sq < 1e-12:
-        return np.linalg.norm(p - a)
-    t = np.clip(np.dot(p - a, ab) / ab_sq, 0.0, 1.0)
-    return np.linalg.norm(p - (a + t * ab))
